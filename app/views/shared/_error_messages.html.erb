<!--バリデーションエラーメッセージを表示するビューファイル-->
<% if object.errors.any? %>
  <div class="alert alert-danger">

    <ul class="mb-0">
      <% object.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>

  </div>
<% end %>

<!--object変数に渡してあげることで、
Boardモデルのインスタンスであろうとも、
Userモデルのインスタンスあろうとも、
エラーメッセージを表示することができる-->