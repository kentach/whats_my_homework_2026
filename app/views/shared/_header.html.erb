<header class="lp-header">
  <div class="header-container">

    <div class="logo-area">
      <%= link_to homeworks_path, class: "d-flex align-items-center text-decoration-none" do %>
        <span class="logo-text">
          <i class="fa-solid fa-book icon"></i>
          What's My <span>Homework?</span>
        </span>
      <% end %>
    </div>

    <button 
      class="hamburger" 
      id="hamburger-btn"
      aria-expanded="false"
      aria-controls="side-menu"
      aria-label="メニューを開く">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<nav id="side-menu" class="side-menu">
  <%= link_to destroy_user_session_path, 
              data: { turbo_method: :delete }, 
              class: "menu-link" do %>
    <i class="fa-solid fa-right-from-bracket"></i> ログアウト
  <% end %>
  <a href="#"><i class="fa-solid fa-star"></i> 機能紹介</a>
  <a href="#"><i class="fa-solid fa-book-open"></i> 使い方ガイド</a>
</nav>

<div id="menu-overlay" class="menu-overlay"></div>